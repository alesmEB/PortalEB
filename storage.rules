rules_version = '2';

// Everything for a work order lives under a single folder named after its
// human-readable code (e.g. "work-orders/A-000001/..."): the generated PDF
// report directly inside, and photos/quotes in their own subfolders as
// those features are built.
//
// Authorization is currently "signed in" only, same as the Data Connect
// connector (every operation there is @auth(level: USER), not permission-
// scoped either) - role/permission enforcement is a client-side UI concern
// for now (see usePermission/HasPermission).
//
// TODO: request.auth.token.role/.permissions are now populated for real
// (see functions/index.js syncUserClaims and firestore.rules), so
// role()/hasPermission() below could be activated - deliberately left
// commented out for now. Doing it properly needs a path-by-path decision,
// not a blind wire-up: e.g. photos/{start,final} are uploaded by whichever
// technician is managing the order (gated client-side by canManageOrder,
// not by the photos:upload permission), so requiring hasPermission
// ('photos:upload') there would actually break that flow. Revisit deliberately.
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // function role() {
    //   return request.auth.token.role;
    // }
    //
    // function hasPermission(permission) {
    //   return isSignedIn() &&
    //     request.auth.token.permissions is list &&
    //     permission in request.auth.token.permissions;
    // }

    // Generated report(s), directly inside the order's folder.
    match /work-orders/{code}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.contentType == 'application/pdf';
    }

    // Videos are capped at 20s client-side (see src/lib/media.ts) - Storage
    // rules can only see file size/type, not duration.
    match /work-orders/{code}/photos/{stage}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        stage in ['start', 'incident', 'final'] &&
        ((request.resource.contentType.matches('image/.*') &&
          request.resource.size < 15 * 1024 * 1024) ||
         (request.resource.contentType.matches('video/.*') &&
          request.resource.size < 20 * 1024 * 1024));
    }

    match /work-orders/{code}/quotes/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.resource.size < 20 * 1024 * 1024 &&
        request.resource.contentType == 'application/pdf';
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
