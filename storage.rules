rules_version = '2';

// Everything for a work order lives under a single folder named after its
// human-readable code (e.g. "work-orders/A-000001/..."): the generated PDF
// report directly inside, and photos/quotes in their own subfolders as
// those features are built.
//
// Authorization: reads are "signed in" only (same broad model as the Data
// Connect connector's @auth(level: USER) - no per-order authorization check
// here, since Storage rules can't query Data Connect/Postgres to verify
// "is this reader actually linked to this order's customer/assignments".
// Closing that would need mirroring authorization data into Firestore, or
// serving downloads through a Cloud Function that checks Data Connect first
// - real gap, but a bigger architecture change than this pass; left as is.
//
// Writes are now permission-scoped (request.auth.token.role/.permissions are
// populated for real - see functions/index.js syncUserClaims and
// firestore.rules). Confirmed against live data before wiring this up:
// every currently-active user already holds photos:upload, and only ADMIN
// users hold quotes:upload (matches the client's own HasPermission gating on
// the quote-upload button) - so this doesn't change who can actually do
// these things today, it just stops anyone signed in but ungranted (e.g. a
// CLIENT account) from doing them directly against the Storage endpoint.
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasPermission(permission) {
      return isSignedIn() &&
        request.auth.token.permissions is list &&
        permission in request.auth.token.permissions;
    }

    // Generated report(s), directly inside the order's folder - only ever
    // written server-side (Admin SDK, createWorkOrder), which bypasses these
    // rules entirely, so this is effectively read-only from any client.
    match /work-orders/{code}/{fileName} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Videos are capped at 20s client-side (see src/lib/media.ts) - Storage
    // rules can only see file size/type, not duration.
    match /work-orders/{code}/photos/{stage}/{fileName} {
      allow read: if isSignedIn();
      allow write: if hasPermission('photos:upload') &&
        stage in ['start', 'incident', 'final'] &&
        ((request.resource.contentType.matches('image/.*') &&
          request.resource.size < 15 * 1024 * 1024) ||
         (request.resource.contentType.matches('video/.*') &&
          request.resource.size < 20 * 1024 * 1024));
    }

    match /work-orders/{code}/quotes/{fileName} {
      allow read: if isSignedIn();
      allow write: if hasPermission('quotes:upload') &&
        request.resource.size < 20 * 1024 * 1024 &&
        request.resource.contentType == 'application/pdf';
    }

    // Images embedded in "EB Engineering" news posts (see EbNewsTab.tsx's
    // rich text editor) - gated behind admin:lab, same as who can write a
    // news post at all right now.
    match /eb-news/{fileName} {
      allow read: if isSignedIn();
      allow write: if hasPermission('admin:lab') &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.size < 10 * 1024 * 1024;
    }

    // Photos/videos attached to a chat message (see ChatPage.tsx) - keyed by
    // orderId (not the human-readable code) since ChatPage only has the id
    // from the route params, same size limits as work order photos. Gated
    // by chat:write, the same permission Firestore's message-create rule
    // already requires.
    match /chat-media/{orderId}/{kind}/{fileName} {
      allow read: if isSignedIn();
      allow write: if hasPermission('chat:write') &&
        kind in ['client', 'technicians'] &&
        ((request.resource.contentType.matches('image/.*') &&
          request.resource.size < 15 * 1024 * 1024) ||
         (request.resource.contentType.matches('video/.*') &&
          request.resource.size < 20 * 1024 * 1024));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
