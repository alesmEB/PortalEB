rules_version = '2';

// Firestore holds: (1) two real-time chats per work order - clientChats
// (admins <-> the customer's linked portal user) and technicianChats
// (admins <-> the technicians currently assigned to that order) - and
// (2) FCM device tokens for push notifications. Everything else (users,
// boats, work orders, time logs, audit trail, quotes) lives in Firebase
// Data Connect / PostgreSQL - see dataconnect/schema.
//
// Chat participants are stored as a uid array directly on each chat
// document (kept in sync by the client whenever technician assignments or
// a customer's linked account change) so rules don't need to look up
// relational Data Connect data at request time.
//
// There's no Cloud Function yet syncing Data Connect role/permissions onto
// Auth custom claims, so request.auth.token has neither - hasPermission()
// checks below can't be enforced server-side yet and are effectively
// client-side only for now (same limitation as every Data Connect
// @auth(level: USER) mutation - see mutations.gql header). "Admin" status is
// mirrored into the adminUsers collection instead (kept in sync by
// AuthContext on every login) specifically so these rules have something to
// check without custom claims.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function isParticipant(chatData) {
      return isSignedIn() &&
        chatData.participants is list &&
        request.auth.uid in chatData.participants;
    }

    function canAccessChat(chatData) {
      return isParticipant(chatData) || isAdmin();
    }

    // A non-admin participant may only ever touch their own lastRead entry
    // (never anyone else's) plus lastMessageAt (bumped when they send a
    // message) - never any other field on the chat doc.
    function participantSelfUpdate(chatData) {
      return canAccessChat(chatData) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastRead', 'lastMessageAt']) &&
        request.resource.data.lastRead.diff(resource.data.lastRead).affectedKeys().hasOnly([request.auth.uid]);
    }

    match /clientChats/{orderId} {
      allow read: if canAccessChat(resource.data);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || participantSelfUpdate(resource.data));
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if canAccessChat(get(/databases/$(database)/documents/clientChats/$(orderId)).data);
        allow create: if canAccessChat(get(/databases/$(database)/documents/clientChats/$(orderId)).data) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
    }

    match /technicianChats/{orderId} {
      allow read: if canAccessChat(resource.data);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || participantSelfUpdate(resource.data));
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if canAccessChat(get(/databases/$(database)/documents/technicianChats/$(orderId)).data);
        allow create: if canAccessChat(get(/databases/$(database)/documents/technicianChats/$(orderId)).data) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
    }

    // Existence-only mirror of "this uid currently has role ADMIN" in Data
    // Connect - see isAdmin() above. Kept in sync by AuthContext on login;
    // a user may only ever write their own doc, so a non-admin can't just
    // grant themselves admin chat access.
    match /adminUsers/{uid} {
      allow read: if false;
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // One document per FCM registration token, keyed by the token itself so
    // re-registering the same token is just an overwrite. Only the owning
    // user can write their own token; reads are server-only (Admin SDK,
    // which bypasses rules) since sending is done from a Cloud Function.
    match /deviceTokens/{token} {
      allow read: if false;
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
