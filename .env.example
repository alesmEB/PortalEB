# Copy to .env.local and fill in with the values from your Firebase project
# settings (Project settings > General > Your apps > SDK setup and
# configuration). These are public client identifiers, not secrets - access
# control is enforced by Firestore/Storage rules and Data Connect, not by
# hiding these values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web Push certificate key pair, from Project settings > Cloud Messaging.
# Required to request an FCM registration token in the browser.
VITE_FIREBASE_VAPID_KEY=

# Data Connect emulator/service location (defaults match `firebase.json`).
VITE_DATA_CONNECT_LOCATION=us-central1
